# MySQL
MYSQL_DATABASE=fraudguard_ai
MYSQL_ROOT_PASSWORD=change_this_mysql_password

# Spring Boot backend
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/fraudguard_ai?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change_this_mysql_password
AI_SERVICE_URL=http://ai-service:8000
JWT_SECRET=fraudguard-development-secret-key-change-before-production-2026
JWT_EXPIRATION_MS=86400000
DEFAULT_ADMIN_EMAIL=admin@fraudguard.ai
DEFAULT_ADMIN_PASSWORD=replace_with_a_strong_password

# Email notifications
MAIL_USERNAME=
MAIL_PASSWORD=
FRAUDGUARD_ESCALATION_RECIPIENT=

# SMS notifications
AFRICASTALKING_SMS_ENABLED=false
AFRICASTALKING_BASE_URL=https://api.sandbox.africastalking.com/version1/messaging
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
FRAUDGUARD_SMS_RECIPIENT=
AFRICASTALKING_SENDER_ID=